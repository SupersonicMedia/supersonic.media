---
import Layout from '../layouts/Layout.astro';

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Super Sonic Media Solutions",
    "alternateName": "Super Sonic",
    "url": "https://supersonic.media",
    "logo": "https://supersonic.media/og-image.png",
    "description": "Modern AI-ready web design studio. We design and develop high-performance websites backed by automation and systems built to drive measurable growth.",
    "address": {
        "@type": "PostalAddress",
        "addressLocality": "Pittsburgh",
        "addressRegion": "PA",
        "addressCountry": "US"
    },
    "sameAs": [
        "https://www.linkedin.com/company/supersonicmedia/"
    ],
    "serviceType": ["Web Design", "Web Development", "AI Solutions", "CRM Implementation"],
    "areaServed": "US"
};
---
<Layout
    title="Super Sonic – Digital Brand Studio"
    description="Modern AI-ready web design studio. We design and develop high-performance websites backed by automation and systems built to drive measurable growth."
    ogTitle="Super Sonic – Digital Brand Studio"
    ogDescription="High-performance websites. Intelligent systems. A studio built for businesses ready to scale."
    ogUrl="https://supersonic.media"
    canonicalUrl="https://supersonic.media/"
    jsonLd={jsonLd}
>
    <!-- Custom cursor -->
    <div class="cursor-dot" id="cursorDot"></div>
    <div class="cursor-ring" id="cursorRing"></div>

    <!-- Hero -->
    <section class="hero" id="heroSection">
        <div class="hero-bg-swoosh"></div>
        <div class="hero-glow" id="heroGlow"></div>
        <img src="/images/icon-fixed.svg" alt="" class="hero-bg-icon" aria-hidden="true">

        <div class="container">
            <span class="hero-tag">Modern AI Ready Web Design</span>
            <h1>Design that turns attention <span class="gold">into action.</span></h1>
            <p class="hero-sub">We design and develop high-performance websites — backed by automation and systems built to drive measurable growth.</p>
            <div class="hero-cta-row">
                <a href="/start/" class="btn-primary">
                    Start a Project
                    <svg viewBox="0 0 16 16" fill="none"><path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <a href="#services" class="btn-ghost">What We Do</a>
            </div>
        </div>
    </section>

    <!-- Services -->
    <section id="services">
        <div class="container">
            <div class="section-tag reveal">What We Do</div>
            <h2 class="section-heading reveal reveal-delay-1">Design first.<br><span style="color: var(--gold)">Systems where they matter.</span></h2>
            <p class="section-desc reveal reveal-delay-2">We build high-performance websites — and layer in the technology that helps them scale.</p>

            <div class="services-grid">
                <a href="/web-design/" class="service-card reveal">
                    <span class="service-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg></span>
                    <h3>Web Design &amp; Development</h3>
                    <p>Strategic, conversion-focused websites built for clarity, speed, and long-term growth. Every project is grounded in positioning and user flow — not decoration.</p>
                    <div class="service-outcomes">
                        <span>Strategic Web Design</span>
                        <span>Custom Development</span>
                        <span>Conversion Optimization</span>
                        <span>Performance &amp; SEO</span>
                    </div>
                    <div class="card-arrow"><svg viewBox="0 0 16 16" fill="none"><path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                </a>
                <a href="/ai-solutions/" class="service-card reveal reveal-delay-1">
                    <span class="service-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></span>
                    <h3>Custom AI Solutions</h3>
                    <p>When automation creates leverage, we build it. From intelligent lead routing to internal workflow systems, we design AI-powered solutions that remove friction and save time.</p>
                    <div class="service-outcomes">
                        <span>Workflow Automation</span>
                        <span>AI Integrations</span>
                        <span>System Architecture</span>
                    </div>
                    <div class="card-arrow"><svg viewBox="0 0 16 16" fill="none"><path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                </a>
                <a href="/crm/" class="service-card reveal reveal-delay-2">
                    <span class="service-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span>
                    <h3>CRM &amp; Growth Infrastructure</h3>
                    <p>A strong website needs structured follow-up. We implement CRM systems that capture leads, automate communication, and keep your pipeline organized.</p>
                    <div class="service-outcomes">
                        <span>Pipeline Management</span>
                        <span>Automated Follow-Up</span>
                        <span>Reporting &amp; Insights</span>
                    </div>
                    <div class="card-arrow"><svg viewBox="0 0 16 16" fill="none"><path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
                </a>
            </div>
        </div>
    </section>

    <!-- Process -->
    <section id="process" style="background: var(--bg-card);">
        <div class="container">
            <div class="section-tag reveal">How We Work</div>
            <h2 class="section-heading reveal reveal-delay-1">A focused process.<br><span style="color: var(--gold)">Built to ship.</span></h2>
            <p class="section-desc reveal reveal-delay-2">Clear direction. Tight execution. No chaos.</p>

            <div class="process-grid">
                <div class="process-card reveal">
                    <div class="process-num">01</div>
                    <h3>Discover</h3>
                    <p>We define positioning, audience, and goals before design begins.</p>
                </div>
                <div class="process-card reveal reveal-delay-1">
                    <div class="process-num">02</div>
                    <h3>Design</h3>
                    <p>We map structure, refine messaging, and prototype key flows.</p>
                </div>
                <div class="process-card reveal reveal-delay-2">
                    <div class="process-num">03</div>
                    <h3>Build</h3>
                    <p>We develop your site with performance, scalability, and clean code in mind.</p>
                </div>
                <div class="process-card reveal reveal-delay-3">
                    <div class="process-num">04</div>
                    <h3>Optimize</h3>
                    <p>We refine conversion points and integrate supporting systems.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Why Us -->
    <section id="why">
        <div class="container">
            <div class="section-tag reveal">Why Super Sonic</div>
            <h2 class="section-heading reveal reveal-delay-1">Not just design.<br><span style="color: var(--gold)">Design that performs.</span></h2>

            <div class="diff-grid">
                <div>
                    <div class="diff-item reveal">
                        <h3>Strategy First</h3>
                        <p>We don't decorate. We design around goals.</p>
                    </div>
                    <div class="diff-item reveal reveal-delay-1">
                        <h3>Performance Built-In</h3>
                        <p>Speed, clarity, and structure aren't afterthoughts.</p>
                    </div>
                    <div class="diff-item reveal reveal-delay-2">
                        <h3>Systems Thinking</h3>
                        <p>Your website connects to the tools that power your business.</p>
                    </div>
                    <div class="diff-item reveal reveal-delay-3">
                        <h3>Built to Scale</h3>
                        <p>We design platforms you won't outgrow in a year.</p>
                    </div>
                </div>
                <div class="diff-visual reveal reveal-delay-2">
                    <div class="diff-image-placeholder">
                        <span>Portfolio image here</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Projects -->
    <section id="projects" style="background: var(--bg-card);">
        <div class="container">
            <div class="section-tag reveal">Selected Work</div>
            <h2 class="section-heading reveal reveal-delay-1">Projects that <span style="color: var(--gold)">speak for themselves.</span></h2>
            <p class="section-desc reveal reveal-delay-2">Web design projects built with strategy, precision, and performance in mind.</p>

            <div class="carousel-wrap reveal" style="margin-top:60px;">
                <div class="carousel-header">
                    <div class="carousel-counter">
                        <span class="current" id="homeCurrentSlide">01</span>
                        <span class="total"> / 09</span>
                    </div>
                    <div class="carousel-nav">
                        <button class="carousel-btn" id="homePrevBtn" aria-label="Previous project">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                        </button>
                        <button class="carousel-btn" id="homeNextBtn" aria-label="Next project">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </button>
                    </div>
                </div>

                <div class="carousel-track-wrapper">
                    <div class="carousel-track" id="homeCarouselTrack">
                        <div class="carousel-card">
                            <div class="card-content">
                                <div class="card-favicon"><img src="https://www.google.com/s2/favicons?domain=thehouserules.com&sz=64" alt="" class="card-favicon-img"><span class="card-favicon-fallback"></span></div>
                                <h3>The House Rules</h3>
                                <p>A high-energy social venue in Scottsdale combining interactive games, elevated food, and craft drinks to create bold, memorable group experiences.</p>
                                <div class="card-tags"><span class="card-tag">Web Design</span><span class="card-tag">Development</span><span class="card-tag">Booking Integration</span></div>
                            </div>
                            <div class="card-image"><div class="card-image-placeholder"><span>Project Preview</span></div></div>
                        </div>
                        <div class="carousel-card">
                            <div class="card-content">
                                <div class="card-favicon"><img src="https://www.google.com/s2/favicons?domain=executivechefsathome.com&sz=64" alt="" class="card-favicon-img"><span class="card-favicon-fallback"></span></div>
                                <h3>Executive Chefs at Home</h3>
                                <p>A private culinary service delivering personalized, chef-driven dining experiences and custom event menus for refined in-home gatherings.</p>
                                <div class="card-tags"><span class="card-tag">Web Design</span><span class="card-tag">Development</span><span class="card-tag">Brand Strategy</span></div>
                            </div>
                            <div class="card-image"><div class="card-image-placeholder"><span>Project Preview</span></div></div>
                        </div>
                        <div class="carousel-card">
                            <div class="card-content">
                                <div class="card-favicon"><img src="https://www.google.com/s2/favicons?domain=playgrounddropout.com&sz=64" alt="" class="card-favicon-img"><span class="card-favicon-fallback"></span></div>
                                <h3>Playground Dropout</h3>
                                <p>A dynamic entertainment destination in Millvale, PA featuring axe throwing, ice curling, and immersive group experiences built around social connection.</p>
                                <div class="card-tags"><span class="card-tag">Web Design</span><span class="card-tag">Development</span><span class="card-tag">UX Strategy</span></div>
                            </div>
                            <div class="card-image"><div class="card-image-placeholder"><span>Project Preview</span></div></div>
                        </div>
                        <div class="carousel-card">
                            <div class="card-content">
                                <div class="card-favicon"><img src="https://www.google.com/s2/favicons?domain=minddojo.com&sz=64" alt="" class="card-favicon-img"><span class="card-favicon-fallback"></span></div>
                                <h3>Mind Dojo</h3>
                                <p>A Pittsburgh-based mental wellness practice offering structured therapy and outpatient programs focused on resilience and long-term wellbeing.</p>
                                <div class="card-tags"><span class="card-tag">Web Design</span><span class="card-tag">Development</span><span class="card-tag">Brand Development</span></div>
                            </div>
                            <div class="card-image"><div class="card-image-placeholder"><span>Project Preview</span></div></div>
                        </div>
                        <div class="carousel-card">
                            <div class="card-content">
                                <div class="card-favicon"><img src="https://www.google.com/s2/favicons?domain=pinkcornerflorals.com&sz=64" alt="" class="card-favicon-img"><span class="card-favicon-fallback"></span></div>
                                <h3>Pink Corner Florals</h3>
                                <p>A boutique floral design studio creating handcrafted arrangements and bespoke installations for weddings and special events.</p>
                                <div class="card-tags"><span class="card-tag">Web Design</span><span class="card-tag">Development</span><span class="card-tag">Brand Development</span></div>
                            </div>
                            <div class="card-image"><div class="card-image-placeholder"><span>Project Preview</span></div></div>
                        </div>
                        <div class="carousel-card">
                            <div class="card-content">
                                <div class="card-favicon"><img src="https://www.google.com/s2/favicons?domain=butlerstreetderby.com&sz=64" alt="" class="card-favicon-img"><span class="card-favicon-fallback"></span></div>
                                <h3>Butler Street Derby</h3>
                                <p>A vibrant Pittsburgh bar and event venue offering classic food, craft drinks, and social entertainment in the heart of Lawrenceville.</p>
                                <div class="card-tags"><span class="card-tag">Web Design</span><span class="card-tag">Development</span><span class="card-tag">Brand Development</span></div>
                            </div>
                            <div class="card-image"><div class="card-image-placeholder"><span>Project Preview</span></div></div>
                        </div>
                        <div class="carousel-card">
                            <div class="card-content">
                                <div class="card-favicon"><img src="https://www.google.com/s2/favicons?domain=prestigebeveragelv.com&sz=64" alt="" class="card-favicon-img"><span class="card-favicon-fallback"></span></div>
                                <h3>Prestige Beverage Las Vegas</h3>
                                <p>A Las Vegas-based beverage brokerage and consulting firm connecting premium and emerging drink brands with hospitality partners for strategic market growth.</p>
                                <div class="card-tags"><span class="card-tag">Web Design</span><span class="card-tag">Development</span><span class="card-tag">Brand Strategy</span></div>
                            </div>
                            <div class="card-image"><div class="card-image-placeholder"><span>Project Preview</span></div></div>
                        </div>
                        <div class="carousel-card">
                            <div class="card-content">
                                <div class="card-favicon"><img src="https://www.google.com/s2/favicons?domain=themindsociety.org&sz=64" alt="" class="card-favicon-img"><span class="card-favicon-fallback"></span></div>
                                <h3>The Mind Society</h3>
                                <p>A nonprofit organization expanding access to mental health education and psychological resources through community-driven initiatives.</p>
                                <div class="card-tags"><span class="card-tag">Web Design</span><span class="card-tag">Development</span><span class="card-tag">Nonprofit</span></div>
                            </div>
                            <div class="card-image"><div class="card-image-placeholder"><span>Project Preview</span></div></div>
                        </div>
                        <div class="carousel-card">
                            <div class="card-content">
                                <div class="card-favicon"><img src="https://www.google.com/s2/favicons?domain=ecftrainingpittsburgh.com&sz=64" alt="" class="card-favicon-img"><span class="card-favicon-fallback"></span></div>
                                <h3>Elite Custom Fitness</h3>
                                <p>A performance-focused strength training facility providing personalized coaching and structured programs designed to deliver measurable results.</p>
                                <div class="card-tags"><span class="card-tag">Web Design</span><span class="card-tag">Development</span></div>
                            </div>
                            <div class="card-image"><div class="card-image-placeholder"><span>Project Preview</span></div></div>
                        </div>
                    </div>
                </div>

                <div class="carousel-progress" id="homeCarouselProgress">
                    <div class="progress-dot active" data-index="0"></div>
                    <div class="progress-dot" data-index="1"></div>
                    <div class="progress-dot" data-index="2"></div>
                    <div class="progress-dot" data-index="3"></div>
                    <div class="progress-dot" data-index="4"></div>
                    <div class="progress-dot" data-index="5"></div>
                    <div class="progress-dot" data-index="6"></div>
                    <div class="progress-dot" data-index="7"></div>
                    <div class="progress-dot" data-index="8"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="cta-section">
        <div class="cta-bg"></div>
        <div class="container">
            <h2 class="reveal">Ready for a website that<br><span class="gold">actually works?</span></h2>
            <p class="cta-sub reveal reveal-delay-1">Tell us what you're building. We'll help you design the system behind it.</p>
            <div class="cta-btn-wrap reveal reveal-delay-2">
                <a href="/start/" class="btn-primary" style="font-size: 14px; padding: 18px 40px;">
                    Start a Project
                    <svg viewBox="0 0 16 16" fill="none"><path d="M3 13L13 3M13 3H5M13 3v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
            </div>
        </div>
    </section>

    <script src="../scripts/reveal.js"></script>
    <script src="../scripts/cursor.js"></script>
    <script src="../scripts/carousel.js"></script>
</Layout>

<style>
    /* === HERO === */
    .hero {
        min-height: min(100vh, 900px);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 160px 80px 100px;
        position: relative;
        overflow: hidden;
    }
    .hero-bg-swoosh { position: absolute; inset: 0; opacity: 0.04; pointer-events: none; background: radial-gradient(ellipse at 80% 50%, var(--gold) 0%, transparent 55%); }
    .hero-bg-icon { position: absolute; top: 50%; right: 5%; transform: translateY(-50%); width: 2400px; height: auto; opacity: 0.035; pointer-events: none; }
    .hero-tag { display: inline-block; font-size: 12px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 32px; opacity: 0; animation: fadeUp 0.7s ease forwards 0.2s; }
    .hero h1 { font-size: clamp(44px, 6.5vw, 88px); line-height: 1.05; font-weight: 800; max-width: 820px; letter-spacing: -1.5px; opacity: 0; animation: fadeUp 0.7s ease forwards 0.35s; }
    .hero h1 .gold { color: var(--gold); }
    .hero-sub { max-width: 520px; margin-top: 28px; font-size: 16px; color: var(--text-dim); line-height: 1.75; font-weight: 400; opacity: 0; animation: fadeUp 0.7s ease forwards 0.5s; }
    .hero-cta-row { display: flex; align-items: center; gap: 16px; margin-top: 44px; opacity: 0; animation: fadeUp 0.7s ease forwards 0.65s; }

    /* === CUSTOM CURSOR === */
    .cursor-dot { width: 8px; height: 8px; background: var(--gold); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9999; transition: transform 0.1s ease; mix-blend-mode: difference; }
    .cursor-ring { width: 40px; height: 40px; border: 1.5px solid var(--gold); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9998; transition: all 0.15s ease-out; opacity: 0.5; }
    .cursor-ring.hovering { width: 64px; height: 64px; border-color: var(--gold); opacity: 0.8; background: rgba(249, 211, 66, 0.06); }
    .hero-glow { position: absolute; width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(249, 211, 66, 0.07) 0%, transparent 70%); pointer-events: none; z-index: 1; opacity: 0; transition: opacity 0.3s; }
    .hero:hover .hero-glow { opacity: 1; }
    @media (max-width: 768px) { .cursor-dot, .cursor-ring { display: none; } }

    /* === CAROUSEL === */
    .carousel-wrap { position: relative; }
    .carousel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 48px; padding-bottom: 24px; border-bottom: 1px solid var(--border); }
    .carousel-counter { font-size: 14px; color: var(--text-dim); font-weight: 500; font-variant-numeric: tabular-nums; }
    .carousel-counter .current { color: var(--gold); font-weight: 700; font-size: 18px; }
    .carousel-counter .total { color: var(--text-dim); }
    .carousel-nav { display: flex; gap: 12px; }
    .carousel-btn { width: 48px; height: 48px; border-radius: 50%; border: 1px solid var(--border); background: transparent; color: var(--text-dim); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all .25s; }
    .carousel-btn:hover { border-color: var(--gold); color: var(--gold); background: rgba(249,211,66,0.06); }
    .carousel-btn svg { width: 18px; height: 18px; }
    .carousel-track-wrapper { overflow: hidden; border-radius: 16px; }
    .carousel-track { display: flex; transition: transform .5s cubic-bezier(0.16,1,0.3,1); }
    .carousel-card { min-width: 100%; display: grid; grid-template-columns: 1fr 1fr; border: 1px solid var(--border); border-radius: 16px; overflow: hidden; background: var(--bg); transition: border-color .3s; }
    .carousel-card:hover { border-color: var(--border-hover); }
    .card-content { padding: 56px 52px; display: flex; flex-direction: column; justify-content: center; }
    .card-favicon { width: 36px; height: 36px; border-radius: 8px; border: 1px solid var(--border); background: var(--bg-card); display: flex; align-items: center; justify-content: center; margin-bottom: 20px; overflow: hidden; position: relative; }
    .card-favicon-img { width: 100%; height: 100%; object-fit: cover; position: relative; z-index: 1; }
    .card-favicon-fallback { position: absolute; width: 10px; height: 10px; border-radius: 2px; background: var(--gold); opacity: 0.3; }
    .card-content h3 { font-size: clamp(24px,2.5vw,36px); font-weight: 800; letter-spacing: -.5px; line-height: 1.15; margin-bottom: 16px; }
    .card-content p { font-size: 15px; color: var(--text-dim); line-height: 1.75; margin-bottom: 24px; max-width: 440px; }
    .card-tags { display: flex; flex-wrap: wrap; gap: 8px; }
    .card-tag { font-size: 11px; font-weight: 600; color: var(--gold); letter-spacing: .5px; padding: 5px 12px; border: 1px solid rgba(249,211,66,0.2); border-radius: 20px; }
    .card-image { position: relative; overflow: hidden; }
    .card-image-placeholder { width: 100%; height: 100%; min-height: 420px; background: linear-gradient(135deg,#0F0F0F 0%,#1A1A1A 50%,#0F0F0F 100%); display: flex; align-items: center; justify-content: center; }
    .card-image-placeholder span { font-size: 13px; color: var(--text-dim); opacity: .3; }
    .carousel-progress { margin-top: 32px; display: flex; gap: 8px; }
    .progress-dot { height: 3px; flex: 1; background: var(--border); border-radius: 2px; cursor: pointer; transition: all .3s; }
    .progress-dot.active { background: var(--gold); }
    .progress-dot:hover { background: rgba(249,211,66,0.4); }

    /* === SECTIONS === */
    section { padding: 120px 80px; position: relative; }

    /* === SERVICES === */
    .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; margin-top: 60px; }
    .service-card { border: 1px solid var(--border); padding: 48px 40px; transition: all 0.35s ease; position: relative; overflow: hidden; text-decoration: none; color: var(--text); display: block; }
    .service-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: var(--gold); transform: scaleX(0); transform-origin: left; transition: transform 0.4s ease; }
    .service-card:hover::before { transform: scaleX(1); }
    .service-card:hover { background: var(--bg-card-hover); border-color: var(--border-hover); }
    .service-icon { width: 40px; height: 40px; border-radius: 10px; border: 1px solid rgba(249,211,66,0.2); background: rgba(249,211,66,0.06); display: flex; align-items: center; justify-content: center; margin-bottom: 24px; color: var(--gold); }
    .service-icon svg { width: 20px; height: 20px; }
    .service-card h3 { font-size: 22px; font-weight: 700; margin-bottom: 16px; letter-spacing: -0.3px; }
    .service-card p { font-size: 14px; color: var(--text-dim); line-height: 1.7; margin-bottom: 8px; }
    .service-outcomes { margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--border); }
