---
import Layout from '../layouts/Layout.astro';
---
<Layout
    title="Start a Project – Super Sonic"
    description="Tell us about your project. We design and develop high-performance websites and growth systems built to perform."
    ogTitle="Start a Project – Super Sonic"
    ogDescription="Tell us about your project. We design and develop high-performance websites and growth systems built to perform."
    ogUrl="https://supersonic.media/start/"
    canonicalUrl="https://supersonic.media/start/"
>
    <section class="form-section">
        <div class="container">
            <div class="form-layout">
                <div class="form-text">
                    <div class="tag">Start a Project</div>
                    <h1>Let's build something <span class="gold">that works.</span></h1>
                    <p class="desc">Tell us what you're working on and what success looks like. We'll get back to you with next steps — whether we're the right fit or not.</p>
                    <div class="form-details">
                        <div class="form-detail-item">
                            <h3>Response Time</h3>
                            <p>We respond within one business day.</p>
                        </div>
                        <div class="form-detail-item">
                            <h3>What Happens Next</h3>
                            <p>A short discovery call to align on goals, scope, and timeline.</p>
                        </div>
                        <div class="form-detail-item">
                            <h3>No Obligation</h3>
                            <p>Every conversation starts with understanding — not a pitch.</p>
                        </div>
                    </div>
                </div>
                <div class="form-embed">
                    <iframe
                        src="https://api.leadconnectorhq.com/widget/form/KMbNnlQv4rxyEfUaI1hE"
                        id="inline-KMbNnlQv4rxyEfUaI1hE"
                        data-layout="{'id':'INLINE'}"
                        data-trigger-type="alwaysShow"
                        data-trigger-value=""
                        data-activation-type="alwaysActivated"
                        data-activation-value=""
                        data-deactivation-type="neverDeactivate"
                        data-deactivation-value=""
                        data-form-name="Form 0"
                        data-height="713"
                        data-layout-iframe-id="inline-KMbNnlQv4rxyEfUaI1hE"
                        data-form-id="KMbNnlQv4rxyEfUaI1hE"
                        title="Form 0"
                    ></iframe>
                    <script src="https://link.msgsndr.com/js/form_embed.js"></script>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .form-section { padding: 160px 80px 120px; position: relative; }
    .form-layout { display: grid; grid-template-columns: 45fr 55fr; gap: 60px; align-items: start; }
    .form-text .tag { font-size: 12px; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); margin-bottom: 20px; opacity: 0; animation: fadeUp 0.7s ease forwards 0.2s; }
    .form-text h1 { font-size: clamp(36px, 5vw, 56px); font-weight: 800; line-height: 1.1; letter-spacing: -1px; max-width: 500px; opacity: 0; animation: fadeUp 0.7s ease forwards 0.35s; }
    .form-text h1 .gold { color: var(--gold); }
    .form-text .desc { margin-top: 24px; font-size: 15px; color: var(--text-dim); line-height: 1.75; max-width: 440px; opacity: 0; animation: fadeUp 0.7s ease forwards 0.5s; }
    .form-details { margin-top: 48px; opacity: 0; animation: fadeUp 0.7s ease forwards 0.65s; }
    .form-detail-item { padding: 20px 0; border-bottom: 1px solid var(--border); }
    .form-detail-item:first-child { border-top: 1px solid var(--border); }
    .form-detail-item h3 { font-size: 14px; font-weight: 700; margin-bottom: 6px; }
    .form-detail-item p { font-size: 13px; color: var(--text-dim); line-height: 1.6; }
    .form-embed { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 32px; min-height: 713px; opacity: 0; animation: fadeUp 0.7s ease forwards 0.5s; display: flex; align-items: center; justify-content: center; }
    .form-embed iframe { width: 100%; max-width: 100%; height: 713px; border: none; border-radius: 8px; }

    @media (max-width: 1024px) {
        .form-section { padding: 140px 40px 80px; }
        .form-layout { gap: 48px; }
    }
    @media (max-width: 768px) {
        .form-section { padding: 120px 24px 60px; }
        .form-layout { grid-template-columns: 1fr; gap: 40px; }
        .form-text h1 { font-size: 32px; }
        .form-embed { padding: 16px; }
    }
</style>
